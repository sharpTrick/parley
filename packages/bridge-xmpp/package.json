    "directory": "packages/bridge-xmpp"
  },
  "homepage": "https://github.com/sharpTrick/parley/tree/main/packages/bridge-xmpp#readme",
  "bugs": {
    "url": "https://github.com/sharpTrick/parley/issues"
  },
  "author": {
    "name": "Patrick Sharp",
