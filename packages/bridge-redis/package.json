{
  "name": "@sharptrick/parley-redis",
  "version": "0.1.0",
  "type": "module",
  "description": "@sharptrick/parley-redis — first event-driven push backend (Redis Streams: XADD id = cursor, XRANGE = fetchRecent, XREAD BLOCK = subscribe). Skeleton against the frozen Parley seam — planned v0.3.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sharpTrick/parley.git",
    "directory": "packages/bridge-redis"
  },
  "homepage": "https://github.com/sharpTrick/parley/tree/main/packages/bridge-redis#readme",
  "bugs": {
    "url": "https://github.com/sharpTrick/parley/issues"
  },
  "author": {
    "name": "Patrick Sharp",
    "url": "https://github.com/sharpTrick"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sharptrick/parley-core": "^0.1.0",
    "@sharptrick/parley-net-util": "^0.1.0",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@sharptrick/parley-conformance": "^0.1.0"
  },
  "keywords": [
    "mcp",
    "parley",
    "redis",
    "message-bus",
    "agent-messaging"
